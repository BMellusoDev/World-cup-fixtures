---
import '../styles/global.css';
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title}</title>
  <!-- Open Graph / social preview -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://world-cup-fixtures.vercel.app/" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content="Todos los resultados históricos de los Mundiales de Fútbol + Mundial 2026" />
  <meta property="og:image" content="https://world-cup-fixtures.vercel.app/posters/1930.jpg" />
  <meta property="og:image:alt" content="World Cup Fixtures" />
  <!-- Twitter card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content="Todos los resultados históricos de los Mundiales de Fútbol + Mundial 2026" />
  <meta name="twitter:image" content="https://world-cup-fixtures.vercel.app/posters/1930.jpg" />
</head>
<body>
  <header class="site-header">
    <div class="container site-header-inner">
      <a href="/" class="site-logo" aria-label="Volver a la pagina principal">
        <img src="/logo.png" alt="World Cup Fixtures" class="site-logo-img" style="height:70px;width:auto;display:block;" />
      </a>
      <nav class="site-nav" id="site-nav">
        <a href="/" class="site-nav-link" data-i18n="navWorldCups">Mundiales</a>
        <a href="/teams" class="site-nav-link" data-i18n="navTeams">Selecciones</a>
      </nav>
      <button class="hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="site-nav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>
  <main style="flex:1;">
    <slot />
  </main>
  <footer class="site-footer">
    <div class="container site-footer-inner">
      <div class="footer-content">
        <span>World Cup Fixtures</span>
        <span class="footer-sep">·</span>
        <span>Hecho con <span aria-label="amor">❤️</span> y <span aria-label="fútbol">⚽</span> por Bruno Melluso</span>
        <span class="footer-sep">·</span>
        <a href="https://github.com/jfjelstul/worldcup" target="_blank" rel="noopener" class="footer-link">Datos: Fjelstul World Cup DB</a>
      </div>
      <div class="footer-social">
        <a href="mailto:brunomellusodev@gmail.com" class="footer-social-link" aria-label="Correo electrónico">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
        <a href="https://github.com/BMellusoDev" target="_blank" rel="noopener" class="footer-social-link" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/bruno-melluso-abb17354/" target="_blank" rel="noopener" class="footer-social-link" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>
  </footer>
  <script is:inline>
    (() => {
      const messages = {
        es: {
          homeTitle: 'World Cup Fixtures',
          homeSubtitle: 'Todos los resultados historicos + Mundial 2026',
          upcomingBadge: 'Proximo',
          upcomingWorldCup: 'Proximo Mundial 2026',
          noMatches: 'No hay partidos cargados para este Mundial.',
          toBePlayed: 'Por jugar',
          versus: 'vs',
          missingPoster: 'Sin cartel',
          navWorldCups: 'Mundiales',
          navTeams: 'Selecciones',
          teamsTitle: 'Selecciones',
          teamsSubtitle: 'Busca una selección y ve todas sus participaciones en los Mundiales',
          teamsPlaceholder: 'Escribe el nombre de una selección…',
          teamsNoResult: 'No se encontraron resultados.',
          worldCup: 'Mundial',
          worldCups: 'Mundiales',
          matches: 'partidos',
          winAbbr: 'V',
          drawAbbr: 'E',
          lossAbbr: 'D',
          learnMore: 'Saber más →',
          penalties: 'penaltis',
          championTitle: '¡Bienvenido, Campeón del Mundo!'
        },
        en: {
          homeTitle: 'World Cup Fixtures',
          homeSubtitle: 'All historical results + 2026 World Cup',
          upcomingBadge: 'Upcoming',
          upcomingWorldCup: 'Upcoming 2026 World Cup',
          noMatches: 'There are no loaded matches for this World Cup.',
          toBePlayed: 'To be played',
          versus: 'vs',
          missingPoster: 'No poster',
          navWorldCups: 'World Cups',
          navTeams: 'National Teams',
          teamsTitle: 'National Teams',
          teamsSubtitle: 'Search for a team and see all their World Cup appearances',
          teamsPlaceholder: 'Type a team name…',
          teamsNoResult: 'No results found.',
          worldCup: 'World Cup',
          worldCups: 'World Cups',
          matches: 'matches',
          winAbbr: 'W',
          drawAbbr: 'D',
          lossAbbr: 'L',
          learnMore: 'Learn more →',
          penalties: 'penalties',
          championTitle: 'Welcome, World Champion!'
        },
        pt: {
          homeTitle: 'Calendario da Copa do Mundo',
          homeSubtitle: 'Todos os resultados historicos + Copa do Mundo 2026',
          upcomingBadge: 'Proximo',
          upcomingWorldCup: 'Proxima Copa do Mundo 2026',
          noMatches: 'Nao ha partidas carregadas para esta Copa do Mundo.',
          toBePlayed: 'A disputar',
          versus: 'vs',
          missingPoster: 'Sem poster',
          navWorldCups: 'Copas do Mundo',
          navTeams: 'Seleções',
          teamsTitle: 'Seleções',
          teamsSubtitle: 'Busque uma seleção e veja todas as participações nas Copas do Mundo',
          teamsPlaceholder: 'Digite o nome de uma seleção…',
          teamsNoResult: 'Nenhum resultado encontrado.',
          worldCup: 'Copa do Mundo',
          worldCups: 'Copas do Mundo',
          matches: 'partidas',
          winAbbr: 'V',
          drawAbbr: 'E',
          lossAbbr: 'D',
          learnMore: 'Saiba mais →',
          penalties: 'pênaltis',
          championTitle: 'Bem-vindo, Campeão do Mundo!'
        }
      };

      function getLocale() {
        const preferred = (navigator.languages && navigator.languages[0]) || navigator.language || 'es';
        const base = preferred.toLowerCase().split('-')[0];
        return messages[base] ? base : 'es';
      }

      function translatePhase(raw, locale) {
        if (!raw) {
          return raw;
        }

        if (locale === 'en') {
          return raw
            .replace(/Grupo/gi, 'Group')
            .replace(/Fecha/gi, 'Matchday')
            .replace(/Fase de grupos/gi, 'Group stage')
            .replace(/Tercer puesto/gi, 'Third place');
        }

        if (locale === 'pt') {
          return raw
            .replace(/Group/gi, 'Grupo')
            .replace(/Matchday/gi, 'Rodada')
            .replace(/Round of 32/gi, 'Dezesseis avos')
            .replace(/Round of 16/gi, 'Oitavas de final')
            .replace(/Quarter-?finals?/gi, 'Quartas de final')
            .replace(/Semi-?finals?/gi, 'Semifinais')
            .replace(/Play-off for third place|Third place/gi, 'Disputa de terceiro lugar');
        }

        return raw
          .replace(/Group/gi, 'Grupo')
          .replace(/Matchday/gi, 'Fecha')
          .replace(/Round of 32/gi, 'Dieciseisavos')
          .replace(/Round of 16/gi, 'Octavos de final')
          .replace(/Quarter-?finals?/gi, 'Cuartos de final')
          .replace(/Semi-?finals?/gi, 'Semifinales')
          .replace(/Play-off for third place|Third place/gi, 'Tercer puesto');
      }

      function applyTranslations() {
        const locale = getLocale();
        const dict = messages[locale];

        document.documentElement.lang = locale;

        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (key && dict[key]) {
            el.textContent = dict[key];
          }
        });

        document.querySelectorAll('[data-match-date]').forEach((el) => {
          const value = el.getAttribute('data-match-date');
          if (!value) {
            return;
          }

          const parsed = new Date(`${value}T00:00:00`);
          if (Number.isNaN(parsed.getTime())) {
            return;
          }

          el.textContent = new Intl.DateTimeFormat(locale, {
            day: '2-digit',
            month: 'short',
            year: 'numeric'
          }).format(parsed);
        });

        document.querySelectorAll('[data-phase]').forEach((el) => {
          const raw = el.getAttribute('data-phase') || '';
          el.textContent = translatePhase(raw, locale);
        });

        document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
          const key = el.getAttribute('data-i18n-placeholder');
          if (key && dict[key]) el.placeholder = dict[key];
        });

        applyFlagFallbackIfNeeded();
      }

      function applyFlagFallbackIfNeeded() {
        const canUseEmojiFlags = supportsFlagEmojiByWidth();

        document.querySelectorAll('.country-flag').forEach((el) => {
          const iso = (el.getAttribute('data-iso') || '').trim().toUpperCase();
          if (!iso || iso.length !== 2) {
            el.textContent = '⚑';
            return;
          }

          el.textContent = canUseEmojiFlags ? toFlagEmoji(iso) : '⚑';
        });
      }

      function supportsFlagEmojiByWidth() {
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        if (!ctx) {
          return false;
        }

        ctx.font = '32px "Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji", sans-serif';
        const flagWidth = ctx.measureText('🇦🇷').width;
        const lettersWidth = ctx.measureText('AR').width;

        return Math.abs(flagWidth - lettersWidth) > 3;
      }

      function toFlagEmoji(isoCode) {
        const points = isoCode
          .toUpperCase()
          .split('')
          .map((char) => 127397 + char.charCodeAt(0));
        return String.fromCodePoint(...points);
      }

      // Expose globally for dynamic scripts on other pages
      window._wcI18n = {
        getLocale: getLocale,
        t: function(key) { return (messages[getLocale()] || messages.es)[key] || key; },
        translatePhase: translatePhase,
        toFlagEmoji: toFlagEmoji,
        supportsFlagEmoji: supportsFlagEmojiByWidth
      };

      document.addEventListener('DOMContentLoaded', applyTranslations);
      document.addEventListener('astro:page-load', applyTranslations);
    })();
  </script>
  <!-- Champion welcome toast -->
  <div id="champion-toast" class="champion-toast" hidden>
    <span id="champion-flag" class="champion-toast-flag"></span>
    <div class="champion-toast-text">
      <span class="champion-toast-title" data-i18n="championTitle">¡Bienvenido, Campeón del Mundo!</span>
      <span class="champion-toast-country" id="champion-country"></span>
    </div>
    <span class="champion-toast-trophy">🏆</span>
  </div>

  <script is:inline>
    (function () {
      if (sessionStorage.getItem('champion-shown')) return;

      var CHAMPIONS = {
        UY: 'Uruguay',
        IT: 'Italia',
        DE: 'Alemania',
        BR: 'Brasil',
        GB: 'Inglaterra',
        AR: 'Argentina',
        FR: 'Francia',
        ES: 'España'
      };

      function toFlagEmoji(iso) {
        return String.fromCodePoint.apply(null, iso.toUpperCase().split('').map(function(c) {
          return 127397 + c.charCodeAt(0);
        }));
      }

      function supportsFlagEmoji() {
        var canvas = document.createElement('canvas');
        var ctx = canvas.getContext('2d');
        if (!ctx) return false;
        ctx.font = '32px serif';
        return Math.abs(ctx.measureText('\uD83C\uDDE6\uD83C\uDDF7').width - ctx.measureText('AR').width) > 3;
      }

      function showToast(iso, countryName) {
        var toast = document.getElementById('champion-toast');
        var flagEl = document.getElementById('champion-flag');
        var countryEl = document.getElementById('champion-country');
        if (!toast || !flagEl || !countryEl) return;

        flagEl.textContent = supportsFlagEmoji() ? toFlagEmoji(iso) : '\uD83C\uDFC6';
        countryEl.textContent = countryName;

        toast.hidden = false;
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            toast.classList.add('champion-toast--show');
          });
        });

        setTimeout(function() {
          toast.classList.remove('champion-toast--show');
          toast.classList.add('champion-toast--hide');
          setTimeout(function() { toast.hidden = true; }, 600);
        }, 7000);

        sessionStorage.setItem('champion-shown', '1');
      }

      fetch('https://ipapi.co/json/')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var iso = (data.country_code || '').toUpperCase();
          if (CHAMPIONS[iso]) showToast(iso, CHAMPIONS[iso]);
        })
        .catch(function() {});
    })();
  </script>

  <script is:inline>
    (function() {
      function initHamburger() {
        const btn = document.getElementById('hamburger');
        const nav = document.getElementById('site-nav');
        if (!btn || !nav) return;

        btn.addEventListener('click', function() {
          const open = nav.classList.toggle('open');
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });

        // Close on link click (navigating away)
        nav.querySelectorAll('.site-nav-link').forEach(function(link) {
          link.addEventListener('click', function() {
            nav.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
          });
        });

        // Close on outside click
        document.addEventListener('click', function(e) {
          if (!nav.contains(e.target) && !btn.contains(e.target)) {
            nav.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
          }
        });
      }

      document.addEventListener('DOMContentLoaded', initHamburger);
      document.addEventListener('astro:page-load', initHamburger);
    })();
  </script>
</body>
</html>