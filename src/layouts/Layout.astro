---
import '../styles/global.css';
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title}</title>
</head>
<body>
  <header class="site-header">
    <div class="container site-header-inner">
      <a href="/" class="site-logo" aria-label="Volver a la pagina principal">
        <img src="/logo.png" alt="World Cup Fixtures" class="site-logo-img" style="height:70px;width:auto;display:block;" />
      </a>
      <nav class="site-nav" id="site-nav">
        <a href="/" class="site-nav-link">Mundiales</a>
        <a href="/teams" class="site-nav-link">Selecciones</a>
      </nav>
      <button class="hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="site-nav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>
  <main style="flex:1;">
    <slot />
  </main>
  <footer class="site-footer">
    <div class="container site-footer-inner">
      <div class="footer-content">
        <span>World Cup Fixtures</span>
        <span class="footer-sep">·</span>
        <span>Hecho con <span aria-label="amor">❤️</span> y <span aria-label="fútbol">⚽</span> por Bruno Melluso</span>
        <span class="footer-sep">·</span>
        <a href="https://github.com/jfjelstul/worldcup" target="_blank" rel="noopener" class="footer-link">Datos: Fjelstul World Cup DB</a>
      </div>
    </div>
  </footer>
  <script is:inline>
    (() => {
      const messages = {
        es: {
          homeTitle: 'World Cup Fixtures',
          homeSubtitle: 'Todos los resultados historicos + Mundial 2026',
          upcomingBadge: 'Proximo',
          upcomingWorldCup: 'Proximo Mundial 2026',
          noMatches: 'No hay partidos cargados para este Mundial.',
          toBePlayed: 'Por jugar',
          versus: 'vs',
          missingPoster: 'Sin cartel'
        },
        en: {
          homeTitle: 'World Cup Fixtures',
          homeSubtitle: 'All historical results + 2026 World Cup',
          upcomingBadge: 'Upcoming',
          upcomingWorldCup: 'Upcoming 2026 World Cup',
          noMatches: 'There are no loaded matches for this World Cup.',
          toBePlayed: 'To be played',
          versus: 'vs',
          missingPoster: 'No poster'
        },
        pt: {
          homeTitle: 'Calendario da Copa do Mundo',
          homeSubtitle: 'Todos os resultados historicos + Copa do Mundo 2026',
          upcomingBadge: 'Proximo',
          upcomingWorldCup: 'Proxima Copa do Mundo 2026',
          noMatches: 'Nao ha partidas carregadas para esta Copa do Mundo.',
          toBePlayed: 'A disputar',
          versus: 'vs',
          missingPoster: 'Sem poster'
        }
      };

      function getLocale() {
        const preferred = (navigator.languages && navigator.languages[0]) || navigator.language || 'es';
        const base = preferred.toLowerCase().split('-')[0];
        return messages[base] ? base : 'es';
      }

      function translatePhase(raw, locale) {
        if (!raw) {
          return raw;
        }

        if (locale === 'en') {
          return raw
            .replace(/Grupo/gi, 'Group')
            .replace(/Fecha/gi, 'Matchday')
            .replace(/Fase de grupos/gi, 'Group stage')
            .replace(/Tercer puesto/gi, 'Third place');
        }

        if (locale === 'pt') {
          return raw
            .replace(/Group/gi, 'Grupo')
            .replace(/Matchday/gi, 'Rodada')
            .replace(/Round of 32/gi, 'Dezesseis avos')
            .replace(/Round of 16/gi, 'Oitavas de final')
            .replace(/Quarter-?finals?/gi, 'Quartas de final')
            .replace(/Semi-?finals?/gi, 'Semifinais')
            .replace(/Play-off for third place|Third place/gi, 'Disputa de terceiro lugar');
        }

        return raw
          .replace(/Group/gi, 'Grupo')
          .replace(/Matchday/gi, 'Fecha')
          .replace(/Round of 32/gi, 'Dieciseisavos')
          .replace(/Round of 16/gi, 'Octavos de final')
          .replace(/Quarter-?finals?/gi, 'Cuartos de final')
          .replace(/Semi-?finals?/gi, 'Semifinales')
          .replace(/Play-off for third place|Third place/gi, 'Tercer puesto');
      }

      function applyTranslations() {
        const locale = getLocale();
        const dict = messages[locale];

        document.documentElement.lang = locale;

        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (key && dict[key]) {
            el.textContent = dict[key];
          }
        });

        document.querySelectorAll('[data-match-date]').forEach((el) => {
          const value = el.getAttribute('data-match-date');
          if (!value) {
            return;
          }

          const parsed = new Date(`${value}T00:00:00`);
          if (Number.isNaN(parsed.getTime())) {
            return;
          }

          el.textContent = new Intl.DateTimeFormat(locale, {
            day: '2-digit',
            month: 'short',
            year: 'numeric'
          }).format(parsed);
        });

        document.querySelectorAll('[data-phase]').forEach((el) => {
          const raw = el.getAttribute('data-phase') || '';
          el.textContent = translatePhase(raw, locale);
        });

        applyFlagFallbackIfNeeded();
      }

      function applyFlagFallbackIfNeeded() {
        const canUseEmojiFlags = supportsFlagEmojiByWidth();

        document.querySelectorAll('.country-flag').forEach((el) => {
          const iso = (el.getAttribute('data-iso') || '').trim().toUpperCase();
          if (!iso || iso.length !== 2) {
            el.textContent = '⚑';
            return;
          }

          el.textContent = canUseEmojiFlags ? toFlagEmoji(iso) : '⚑';
        });
      }

      function supportsFlagEmojiByWidth() {
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        if (!ctx) {
          return false;
        }

        ctx.font = '32px "Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji", sans-serif';
        const flagWidth = ctx.measureText('🇦🇷').width;
        const lettersWidth = ctx.measureText('AR').width;

        return Math.abs(flagWidth - lettersWidth) > 3;
      }

      function toFlagEmoji(isoCode) {
        const points = isoCode
          .toUpperCase()
          .split('')
          .map((char) => 127397 + char.charCodeAt(0));
        return String.fromCodePoint(...points);
      }

      document.addEventListener('DOMContentLoaded', applyTranslations);
      document.addEventListener('astro:page-load', applyTranslations);
    })();
  </script>
  <!-- Champion welcome toast -->
  <div id="champion-toast" class="champion-toast" hidden>
    <span id="champion-flag" class="champion-toast-flag"></span>
    <div class="champion-toast-text">
      <span class="champion-toast-title">¡Bienvenido, Campeón del Mundo!</span>
      <span class="champion-toast-country" id="champion-country"></span>
    </div>
    <span class="champion-toast-trophy">🏆</span>
  </div>

  <script is:inline>
    (function () {
      if (sessionStorage.getItem('champion-shown')) return;

      var CHAMPIONS = {
        UY: 'Uruguay',
        IT: 'Italia',
        DE: 'Alemania',
        BR: 'Brasil',
        GB: 'Inglaterra',
        AR: 'Argentina',
        FR: 'Francia',
        ES: 'España'
      };

      function toFlagEmoji(iso) {
        return String.fromCodePoint.apply(null, iso.toUpperCase().split('').map(function(c) {
          return 127397 + c.charCodeAt(0);
        }));
      }

      function supportsFlagEmoji() {
        var canvas = document.createElement('canvas');
        var ctx = canvas.getContext('2d');
        if (!ctx) return false;
        ctx.font = '32px serif';
        return Math.abs(ctx.measureText('\uD83C\uDDE6\uD83C\uDDF7').width - ctx.measureText('AR').width) > 3;
      }

      function showToast(iso, countryName) {
        var toast = document.getElementById('champion-toast');
        var flagEl = document.getElementById('champion-flag');
        var countryEl = document.getElementById('champion-country');
        if (!toast || !flagEl || !countryEl) return;

        flagEl.textContent = supportsFlagEmoji() ? toFlagEmoji(iso) : '\uD83C\uDFC6';
        countryEl.textContent = countryName;

        toast.hidden = false;
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            toast.classList.add('champion-toast--show');
          });
        });

        setTimeout(function() {
          toast.classList.remove('champion-toast--show');
          toast.classList.add('champion-toast--hide');
          setTimeout(function() { toast.hidden = true; }, 600);
        }, 7000);

        sessionStorage.setItem('champion-shown', '1');
      }

      fetch('https://ipapi.co/json/')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var iso = (data.country_code || '').toUpperCase();
          if (CHAMPIONS[iso]) showToast(iso, CHAMPIONS[iso]);
        })
        .catch(function() {});
    })();
  </script>

  <script is:inline>
    (function() {
      function initHamburger() {
        const btn = document.getElementById('hamburger');
        const nav = document.getElementById('site-nav');
        if (!btn || !nav) return;

        btn.addEventListener('click', function() {
          const open = nav.classList.toggle('open');
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });

        // Close on link click (navigating away)
        nav.querySelectorAll('.site-nav-link').forEach(function(link) {
          link.addEventListener('click', function() {
            nav.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
          });
        });

        // Close on outside click
        document.addEventListener('click', function(e) {
          if (!nav.contains(e.target) && !btn.contains(e.target)) {
            nav.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
          }
        });
      }

      document.addEventListener('DOMContentLoaded', initHamburger);
      document.addEventListener('astro:page-load', initHamburger);
    })();
  </script>
</body>
</html>