---
import Layout from '../layouts/Layout.astro';
import WorldCupSelector from '../components/WorldCupSelector.astro';
import { db } from '../lib/db.js';

const worldcups = db.getWorldCups();
const upcoming = worldcups.find((wc) => wc.upcoming) || worldcups[0] || null;

const firstMatch = [...(upcoming?.matches || [])]
  .filter((match) => !!match.date)
  .sort((a, b) => Number(a.id || 0) - Number(b.id || 0))[0] || null;

const firstKickoff = firstMatch
  ? {
      date: firstMatch.date || '',
      time: /^\d{2}:\d{2}$/.test(String((firstMatch as any).time || '').trim())
        ? String((firstMatch as any).time).trim()
        : '00:00'
    }
  : null;

const homeBootstrap = JSON.stringify({
  kickoffDate: firstKickoff?.date || '',
  kickoffTime: firstKickoff?.time || '',
  sourceTimeZone: upcoming?.sourceTimeZone || ''
});
---

<Layout title="World Cup Fixtures">
  <main class="container page-home">
    <h1 data-i18n="homeTitle">World Cup Fixtures</h1>
    <p class="subtitle" data-i18n="homeSubtitle">Todos los resultados históricos + Mundial 2026</p>
    <section class="tournament-countdown" id="home-countdown-card">
      <p class="muted">Cuenta regresiva al inicio</p>
      <p id="home-countdown-value" class="tournament-countdown-value">Calculando...</p>
      <p id="home-countdown-note" class="tournament-countdown-note"></p>
    </section>
    <WorldCupSelector worldcups={worldcups} />
  </main>
  <script id="home-bootstrap" type="application/json" set:html={homeBootstrap}></script>
</Layout>

<script>
  // @ts-nocheck
  (() => {
    const raw = document.getElementById('home-bootstrap')?.textContent || '{}';
    const { kickoffDate = '', kickoffTime = '', sourceTimeZone = 'Europe/Madrid' } = JSON.parse(raw);

    const card = document.getElementById('home-countdown-card');
    const valueEl = document.getElementById('home-countdown-value');
    const noteEl = document.getElementById('home-countdown-note');

    function getTimeZoneOffsetMs(date, timeZone) {
      const parts = new Intl.DateTimeFormat('en-US', {
        timeZone,
        hour12: false,
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit'
      }).formatToParts(date);

      const byType = Object.fromEntries(parts.map((p) => [p.type, p.value]));
      const asUTC = Date.UTC(
        Number(byType.year),
        Number(byType.month) - 1,
        Number(byType.day),
        Number(byType.hour),
        Number(byType.minute),
        Number(byType.second)
      );

      return asUTC - date.getTime();
    }

    function parseSourceKickoff(dateStr, timeStr) {
      const [year, month, day] = String(dateStr || '').split('-').map(Number);
      const [hour, minute] = String(timeStr || '00:00').split(':').map(Number);
      if (!year || !month || !day || Number.isNaN(hour) || Number.isNaN(minute)) return null;

      let utcGuess = Date.UTC(year, month - 1, day, hour, minute, 0);
      for (let i = 0; i < 3; i += 1) {
        const offset = getTimeZoneOffsetMs(new Date(utcGuess), sourceTimeZone);
        utcGuess = Date.UTC(year, month - 1, day, hour, minute, 0) - offset;
      }

      const result = new Date(utcGuess);
      return Number.isNaN(result.getTime()) ? null : result;
    }

    const formatRemainingMs = (ms) => {
      const totalSeconds = Math.max(0, Math.floor(ms / 1000));
      const days = Math.floor(totalSeconds / 86400);
      const hours = Math.floor((totalSeconds % 86400) / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;
      return `${days}d ${String(hours).padStart(2, '0')}h ${String(minutes).padStart(2, '0')}m ${String(seconds).padStart(2, '0')}s`;
    };

    function renderHomeCountdown() {
      if (!card || !valueEl || !noteEl) return;
      if (!kickoffDate) {
        card.hidden = true;
        return;
      }

      const time = /^\d{2}:\d{2}$/.test(String(kickoffTime || '').trim()) ? kickoffTime : '00:00';
      const kickoff = parseSourceKickoff(kickoffDate, time);
      if (!kickoff || Number.isNaN(kickoff.getTime())) {
        valueEl.textContent = 'Fecha inválida';
        noteEl.textContent = '';
        return;
      }

      const diff = kickoff.getTime() - Date.now();
      valueEl.textContent = diff <= 0 ? 'El Mundial ya comenzó' : formatRemainingMs(diff);
      noteEl.textContent = `Inicio estimado: ${new Intl.DateTimeFormat('es', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }).format(kickoff)} (hora local de tu dispositivo)`;
    }

    renderHomeCountdown();
    window.setInterval(renderHomeCountdown, 1000);
  })();
</script>